<?xml version="1.0" encoding="utf-8"?>
<component name="LibraryScene" extends="Scene">
    <children>
        <!-- Header -->
        <Rectangle height="100" width="1280" color="#1a1a2e">
            <Rectangle height="60" width="160" translation="[20,20]">
                <Button height="60" width="160" title="Back" id="backButton" />
            </Rectangle>
            <Label height="60" width="800" translation="[200,20]"
                   text="Library"
                   font="font:LargeBoldSystemFont"
                   color="#FFFFFF"
                   id="titleLabel" />
        </Rectangle>

        <!-- Items Grid -->
        <PosterGrid height="540" width="1280" translation="[0,100]"
                    numColumns="5" numRows="3"
                    itemSpacing="[20, 15]"
                    basePosterSize="[220, 330]"
                    caption1Icon="handle://leftbottom"
                    id="itemsGrid">
            <ContentEmitter />
        </PosterGrid>

        <!-- Description Area -->
        <Rectangle height="40" width="1280" translation="[0,640]" color="#0d0d1a">
            <Label height="40" width="1200" translation="[40,8]"
                   text="Select an item"
                   font="font:MediumSystemFont"
                   color="#AAAAAA"
                   id="descriptionLabel" />
        </Rectangle>
    </children>
</component>