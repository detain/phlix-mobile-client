<?xml version="1.0" encoding="utf-8"?>
<component name="LoginScene" extends="Scene">
    <interface>
        <field id="OnLoginSuccess" type="func" />
    </interface>
    <children>
        <!-- Background -->
        <Rectangle height="720" width="1280" color="#0d0d1a" />

        <!-- Login Container -->
        <Rectangle height="500" width="500" translation="[390,110]" color="#1a1a2e">
            <!-- Title -->
            <Label height="60" width="460" translation="[20,20]"
                   text="Phlex"
                   font="font:LargeBoldSystemFont"
                   color="#FFFFFF"
                   halign="center" />

            <!-- Server URL -->
            <Label height="30" width="460" translation="[20,90]"
                   text="Server URL"
                   font="font:SmallSystemFont"
                   color="#AAAAAA" />
            <TextEditBox height="50" width="460" translation="[20,120]"
                         hint="http://localhost:8096"
                         id="serverInput" />

            <!-- Username -->
            <Label height="30" width="460" translation="[20,180]"
                   text="Username"
                   font="font:SmallSystemFont"
                   color="#AAAAAA" />
            <TextEditBox height="50" width="460" translation="[20,210]"
                         hint="Username"
                         id="usernameInput" />

            <!-- Password -->
            <Label height="30" width="460" translation="[20,270]"
                   text="Password"
                   font="font:SmallSystemFont"
                   color="#AAAAAA" />
            <TextEditBox height="50" width="460" translation="[20,300]"
                         hint="Password"
                         secure="true"
                         id="passwordInput" />

            <!-- Error Label -->
            <Label height="30" width="460" translation="[20,360]"
                   text=""
                   font="font:SmallSystemFont"
                   color="#FF4444"
                   visible="false"
                   id="errorLabel" />

            <!-- Status Label -->
            <Label height="30" width="460" translation="[20,360]"
                   text=""
                   font="font:SmallSystemFont"
                   color="#0095d5"
                   visible="false"
                   id="statusLabel" />

            <!-- Login Button -->
            <Button height="60" width="460" translation="[20,400]"
                    title="Login"
                    id="loginButton" />
        </Rectangle>
    </children>
</component>