<?xml version="1.0" encoding="utf-8"?>
<component name="DetailScene" extends="Scene">
    <interface>
        <field id="itemId" type="string" />
    </interface>
    <children>
        <!-- Background -->
        <Rectangle height="720" width="1280" color="#0d0d1a" />

        <!-- Header -->
        <Rectangle height="100" width="1280" color="#1a1a2e">
            <Rectangle height="60" width="160" translation="[20,20]">
                <Button height="60" width="160" title="Back" id="backButton" />
            </Rectangle>
        </Rectangle>

        <!-- Content Area -->
        <Rectangle height="580" width="1280" translation="[0,100]">
            <!-- Poster -->
            <Rectangle height="400" width="280" translation="[40,40]">
                <Poster height="400" width="280" id="posterImage"
                         failedUrl="pkg:/images/placeholder.png"
                         defaultUrl="pkg:/images/placeholder.png" />
            </Rectangle>

            <!-- Info Panel -->
            <Rectangle height="400" width="880" translation="[360,40]">
                <Label height="60" width="860" translation="[10,0]"
                       font="font:LargeBoldSystemFont"
                       color="#FFFFFF"
                       id="titleLabel" />

                <Label height="40" width="860" translation="[10,70]"
                       font="font:MediumSystemFont"
                       color="#AAAAAA"
                       id="infoLabel" />

                <Rectangle height="200" width="860" translation="[10,120]">
                    <Label height="200" width="860"
                           font="font:SmallSystemFont"
                           color="#CCCCCC"
                           id="descriptionLabel"
                           wrap="true" />
                </Rectangle>

                <Button height="60" width="200" translation="[10,330]"
                        title="Play"
                        id="playButton" />
            </Rectangle>
        </Rectangle>
    </children>
</component>