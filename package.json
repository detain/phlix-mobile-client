{
  "name": "phlix-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "A cross-platform mobile application for media playback",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "build:android:debug": "cd android && ./gradlew assembleDebug",
    "build:android:release": "cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@notifee/react-native": "^9.1.8",
    "@phlix/contracts": "github:detain/phlix-contracts#v0.3.9",
    "@phlix/syncplay": "github:detain/phlix-syncplay#v0.1.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/cli-platform-android": "^20.2.0",
    "@react-native-community/cli-server-api": "^20.2.0",
    "@react-native-community/slider": "^5.2.0",
    "@react-navigation/bottom-tabs": "^7.18.3",
    "@react-navigation/native": "^7.3.4",
    "@react-navigation/native-stack": "^7.17.6",
    "axios": "^1.6.8",
    "react": "19.2.7",
    "react-native": "0.85.3",
    "react-native-config": "^1.6.1",
    "react-native-gesture-handler": "^3.0.2",
    "react-native-keychain": "^10.0.0",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-reanimated": "^4.5.0",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.25.2",
    "react-native-worklets": "^0.10.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@babel/preset-env": "^7.24.5",
    "@babel/runtime": "^7.24.5",
    "@react-native-community/cli": "^20.2.0",
    "@react-native-community/cli-platform-ios": "^20.2.0",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.1.1",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "typescript": "5.4.5"
  },
  "overrides": {
